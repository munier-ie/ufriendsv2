# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/ufriendsv2?schema=public"

# Authentication
JWT_SECRET="generate-a-long-random-string-here"
PORT=3000

# Security (CRITICAL)
# Used for encrypting BVN/NIN in the database. Use 32 characters.
ENCRYPTION_KEY="32-character-random-string-here"

# Monnify (Virtual Accounts)
MONNIFY_API_KEY=""
MONNIFY_SECRET_KEY=""
MONNIFY_CONTRACT_CODE=""
MONNIFY_BASE_URL="https://api.monnify.com"
MONNIFY_STATUS="Off" # On/Off

# PaymentPoint (Virtual Accounts alternative)
PAYMENTPOINT_API_KEY=""
PAYMENTPOINT_SECRET_KEY=""
PAYMENTPOINT_BUSINESS_ID=""
PAYMENTPOINT_BASE_URL="https://api.paymentpoint.co"
PAYMENTPOINT_STATUS="Off"

# Email Configuration (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=465
SMTP_SECURE="true"
SMTP_USER="user@example.com"
SMTP_PASS="password"
SMTP_STATUS="Off"
EMAIL_FROM='"Ufriends Support" <support@ufriends.com>'
ADMIN_EMAIL="admin@ufriends.com"

# External URLs
FRONTEND_URL="https://ufriends.com.ng"

# Puppeteer (PDF Generation)
# CHROME_BIN="/usr/bin/google-chrome" # Uncomment and set if needed
